#!/usr/bin/env bash
set -euo pipefail

job_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
stdout_file="$(mktemp)"
stderr_file="$(mktemp)"
trap 'rm -f "$stdout_file" "$stderr_file"' EXIT

if docker compose --project-directory "$job_dir" run --rm restic snapshots >"$stdout_file" 2>"$stderr_file"; then
  exit 0
fi

if grep -Eiq 'config file|repository.*does not exist|Is there a repository' "$stderr_file"; then
  docker compose --project-directory "$job_dir" run --rm restic init
  exit 0
fi

cat "$stderr_file" >&2
exit 1
