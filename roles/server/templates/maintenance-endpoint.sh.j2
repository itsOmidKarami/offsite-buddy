#!/usr/bin/env bash
set -euo pipefail

job_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cleanup() {
  local original_status=$?
  local maintenance_status=0
  local restore_status=0
  local artifact_status=0
  trap - EXIT HUP INT TERM
  set +e
  docker compose --project-directory "$job_dir" \
    -f "$job_dir/compose.maintenance.yaml" down --remove-orphans
  maintenance_status=$?
  docker compose --project-directory "$job_dir" \
    -f "$job_dir/compose.yaml" up -d
  restore_status=$?
  if [ "$maintenance_status" -eq 0 ] && [ "$restore_status" -eq 0 ]; then
    rm -f "$job_dir/compose.maintenance.yaml" \
      "$job_dir/maintenance-endpoint.sh"
    artifact_status=$?
  fi
  if [ "$restore_status" -ne 0 ]; then
    exit "$restore_status"
  fi
  if [ "$maintenance_status" -ne 0 ]; then
    exit "$maintenance_status"
  fi
  if [ "$artifact_status" -ne 0 ]; then
    exit "$artifact_status"
  fi
  exit "$original_status"
}

trap cleanup EXIT
trap 'exit 129' HUP
trap 'exit 130' INT
trap 'exit 143' TERM
docker compose --project-directory "$job_dir" \
  -f "$job_dir/compose.yaml" down
docker compose --project-directory "$job_dir" \
  -f "$job_dir/compose.maintenance.yaml" up -d
printf '%s\n' \
  'Maintenance endpoint active for {{ friend.name }}. Press Enter to restore append-only mode.'
read -r _
